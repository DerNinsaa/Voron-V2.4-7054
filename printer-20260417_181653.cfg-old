[include mmu/base/*.cfg]
[include mmu/optional/client_macros.cfg]
[include fluidd.cfg]
[include toolhead_beacon.cfg]
[include mainboard.cfg]
[include toolhead.cfg]
[include toolhead_leds.cfg]
[include macros.cfg]
[include stepper-tune.cfg]
[include KAMP_Settings.cfg]
[include config_backup.cfg]
[include goose_purge.cfg]
[virtual_sdcard]
path: /home/ninsaa/printer_data/gcodes
on_error_gcode: CANCEL_PRINT
[exclude_object]
[firmware_retraction]
retract_length: 0.5
retract_speed: 35.0
unretract_speed: 35.0
unretract_extra_length: 0
[danger_options]

[pause_resume]
[printer]
kinematics: corexy
max_velocity: 300  
max_accel: 4000    			
max_z_velocity: 15 			
max_z_accel: 350
square_corner_velocity: 5.0

[mcu]
serial: /dev/serial/by-id/usb-Klipper_stm32h723xx_0F002B001851313434373135-if00

[quad_gantry_level]
gantry_corners:
    0,0
    350,350
points:
    30,0 #front left
    30,290 #back left
    320,290 #back right
    320,0 #front right
speed: 75
max_adjust: 10
retries: 5
retry_tolerance: 0.05
adaptive_horizontal_move_z: true
min_horizontal_move_z: 1.0

[bed_mesh]
zero_reference_position: 175, 175
speed: 400
horizontal_move_z: 5
mesh_min: 30, 30
mesh_max: 320, 290
probe_count: 30, 30
algorithm: bicubic

[extruder]
#control: pid
#pid_Kp: 21.196 
#pid_Ki: 1.017 
#pid_Kd: 110.482

[skew_correction]

[gcode_arcs]
resolution: 0.1

[shaketune]
result_folder: ~/printer_data/config/ShakeTune_results
number_of_results_to_keep: 3
keep_raw_data: False
show_macros_in_webui: True
timeout: 300

